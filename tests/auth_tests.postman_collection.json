							"    pm.response.to.have.status(400);",
							"});",
							"",
							"pm.test(\"Response contains validation error details\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.error).to.include(\"Validation error\");",
							"});"
						],
						"type": "text/javascript",
						"packages": {}
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"email\": \"invalid-email-format\",\n    \"password\": \"password123\",\n    \"user_name\": \"test_user_validation\"\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{base_url}}/auth/sign-up",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"auth",
						"sign-up"
					]
				},
				"description": "Fails validation due to an invalid email format."
			},
			"response": []
		},
		{
			"name": "3. Signup - Validation Failure (Short Password)",
