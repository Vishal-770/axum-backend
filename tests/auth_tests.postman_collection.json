		{
			"name": "12. Login - Success",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200 OK\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"User profile is returned without tokens in JSON\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData).to.have.property(\"user\");",
							"    pm.expect(jsonData.user).to.have.property(\"id\");",
							"    pm.expect(jsonData.user.email).to.eql(pm.collectionVariables.get(\"test_email\"));",
							"    pm.expect(jsonData).to.not.have.property(\"access_token\");",
							"    pm.expect(jsonData).to.not.have.property(\"refresh_token\");",
							"});",
							"",
							"pm.test(\"Cookies access_token and refresh_token are set\", function () {",
							"    pm.expect(pm.cookies.has(\"access_token\")).to.be.true;",
							"    pm.expect(pm.cookies.has(\"refresh_token\")).to.be.true;",
							"});"
						],
						"type": "text/javascript",
						"packages": {}
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"body": {
