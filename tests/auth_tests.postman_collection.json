							"    pm.response.to.have.status(400);",
							"});",
							"",
							"pm.test(\"Response contains password validation message\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.error).to.include(\"Password must be at least 6 characters long\");",
							"});"
						],
						"type": "text/javascript",
						"packages": {}
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"email\": \"validemail@example.com\",\n    \"password\": \"123\",\n    \"user_name\": \"test_user_pwd\"\n}",
