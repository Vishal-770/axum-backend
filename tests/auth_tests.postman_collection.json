		{
			"name": "5. Signup - Overwrite (Unverified User)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 201 Created\", function () {",
							"    pm.response.to.have.status(201);",
							"});",
							"",
							"pm.test(\"Successfully overwrites unverified user's credentials\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.username).to.eql(\"test_user_overwritten\");",
							"    pm.expect(jsonData.verified).to.be.false;",
							"});"
						],
						"type": "text/javascript",
						"packages": {}
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"email\": \"{{test_email}}\",\n    \"password\": \"newpassword789\",\n    \"user_name\": \"test_user_overwritten\"\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{base_url}}/auth/sign-up",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"auth",
						"sign-up"
					]
				},
				"description": "Submits signup with the same unverified email. This triggers the overwrite branch: it updates the user profile and generates/saves a new OTP in-place (without deleting the database row)."
			},
			"response": []
		},
		{
			"name": "6. Verify Email - Validation Failure (Wrong OTP Length)",
