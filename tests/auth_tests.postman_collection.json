		{
			"name": "13. Refresh - Success",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200 OK\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"Response body does not contain tokens\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.message).to.eql(\"Tokens refreshed successfully\");",
							"    pm.expect(jsonData).to.not.have.property(\"access_token\");",
							"});",
							"",
							"pm.test(\"New cookies are set\", function () {",
							"    pm.expect(pm.cookies.has(\"access_token\")).to.be.true;",
							"    pm.expect(pm.cookies.has(\"refresh_token\")).to.be.true;",
							"});"
						],
						"type": "text/javascript",
						"packages": {}
