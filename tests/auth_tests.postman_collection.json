							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.error).to.include(\"OTP must be exactly 6 digits\");",
							"});"
						],
						"type": "text/javascript",
						"packages": {}
					}
				}
			],
			"request": {
				"method": "POST",
