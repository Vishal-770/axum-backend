{
	"info": {
		"_postman_id": "7d4b4a1b-c12a-4db3-9821-1d0b3017a421",
		"name": "Auth Signup and Verification Tests",
		"description": "Collection of requests testing all edge cases for /auth/sign-up and /auth/verify-email endpoints, including validation, conflicts, overwrites, and successful verification.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Signup - Success (New User)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 201 Created\", function () {",
							"    pm.response.to.have.status(201);",
							"});",
							"",
							"pm.test(\"Response has user details with verified = false\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData).to.have.property(\"id\");",
							"    pm.expect(jsonData.email).to.eql(pm.collectionVariables.get(\"test_email\"));",
							"    pm.expect(jsonData.verified).to.be.false;",
							"});"
						],
						"type": "text/javascript",
						"packages": {}
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"email\": \"{{test_email}}\",\n    \"password\": \"password123\",\n    \"user_name\": \"test_user_new\"\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{base_url}}/auth/sign-up",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"auth",
						"sign-up"
					]
				},
				"description": "Registers a new user for the first time. The email will be marked as unverified, and an OTP will be saved to the database and sent to the email."
			},
			"response": []
		},
		{
