{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT pr.id, pr.token_hash, pr.expires_at\n        FROM password_resets pr\n        JOIN users u ON pr.user_id = u.id\n        WHERE u.email = $1 AND pr.used_at IS NULL AND pr.expires_at > $2\n        ORDER BY pr.created_at DESC\n        LIMIT 1\n        ",
